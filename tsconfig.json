{
    "compilerOptions": {
        "lib": [
            "ES2023"
        ],
        "module": "Node16",
        "target": "ES2022",
        "moduleResolution": "Node16",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "jsx": "react-jsx"
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx"
    ]
}